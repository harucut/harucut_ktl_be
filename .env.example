# ── 환경변수 템플릿 ────────────────────────────────────────────
# 이 파일을 복사해 .env / .env.staging / .env.prod 를 만드세요.
# 이 파일은 git에 포함됩니다. 실제 값은 절대 여기에 쓰지 마세요.

# MySQL (staging / prod 전용)
DB_HOST=
DB_PORT=3306
DB_NAME=harucut
DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Redis
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (256비트 이상 랜덤 문자열)
JWT_SECRET_KEY=

# OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# AWS S3
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
S3_BUCKET=

# Mail (SMTP)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
